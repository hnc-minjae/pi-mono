{
  "identifier": "default",
  "description": "Default capabilities for Han AI Desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:default",
    {
      "identifier": "fs:allow-read",
      "allow": [
        { "path": "$DOCUMENT/**" },
        { "path": "$APPDATA/**" },
        { "path": "$HOME/.config/han/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [
        { "path": "$DOCUMENT/**" },
        { "path": "$APPDATA/**" },
        { "path": "$HOME/.config/han/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$DOCUMENT/**" },
        { "path": "$APPDATA/**" },
        { "path": "$HOME/.config/han/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$DOCUMENT/**" },
        { "path": "$APPDATA/**" },
        { "path": "$HOME/.config/han/**" }
      ]
    },
    "shell:allow-open"
  ]
}
